# Inloggning (webbappen)
APP_PASSWORD=svta2026

# Claude / Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn API (OAuth 2.0 member token — not client_credentials)
# App credentials (Developer → Auth) — used only to GET an access_token, not in the post HTTP call itself:
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_primary_client_secret_here
# Must match exactly one "Authorized redirect URLs for your app" in LinkedIn Developer → Auth:
LINKEDIN_REDIRECT_URI=http://localhost:8765/linkedin-callback
# Run: python linkedin_automatisering/linkedin_oauth_exchange.py  → then paste output lines below.
# Token must be obtained with scopes: openid profile email w_member_social
# - openid + profile + email → required for https://api.linkedin.com/v2/userinfo (403 without openid)
# - w_member_social → post as member (Share on LinkedIn product)
# Developer app: enable "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn".
# Person-URN: urn:li:person:<sub> where <sub> comes from GET /v2/userinfo (run print_linkedin_person_urn.py).
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID
# Posta som företagssida (valfritt — annars används din personprofil):
# Numeriskt org-id (hittas t.ex. i admin-URL för sidan eller via LinkedIn). Token måste ha w_organization_social.
LINKEDIN_ORGANIZATION_ID=
# Eller sätt full author-URN (person eller organisation), då ignoreras person/org-id ovan:
LINKEDIN_POST_AUTHOR_URN=
# Valfritt: REST Posts API månadsversion (YYYYMM). Standard 202505. Öka om LinkedIn svarar 400 på /rest/posts.
LINKEDIN_API_VERSION=202506

# Sitesmart (webbformulär)
SITESMART_BASE_URL=https://your-sitesmart-domain.example
SITESMART_USERNAME=your_username
SITESMART_PASSWORD=your_password

# Valfritt: var du vill starta flödet (t.ex. "lägg till talare"-sidan)
SITESMART_SPEAKER_FORM_URL=
